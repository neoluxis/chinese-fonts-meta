pkgname=basic-fonts-meta
pkgver=1.0
pkgrel=1
pkgdesc="Meta package for basic fonts"
arch=('any')
depends=(
    noto-fonts
    ttf-dejavu
    ttf-liberation
    adwaita-fonts
)

package() {
    echo "-----------------"
    for i in "${!depends[@]}"; do
        printf "%2d: %s\n" "$i" "${depends[$i]}"
    done
    echo "-----------------"
    
    mkdir -p "$pkgdir"
}
